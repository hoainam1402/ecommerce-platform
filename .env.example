# ============================================================
# E-Commerce Platform — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên Git!
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
API_PREFIX=api/v1

# ─── Database (PostgreSQL) ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=ecom_user
DB_PASSWORD=ecom_pass_local
DB_NAME=ecom_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass_local
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ─── JWT ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_RANDOM_64_BYTES_HEX
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_RANDOM_64_BYTES_HEX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── Storage (MinIO local / S3 production) ───────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minio_admin
STORAGE_SECRET_KEY=minio_pass_local
STORAGE_BUCKET=ecom-media
STORAGE_REGION=ap-southeast-1
STORAGE_PUBLIC_URL=http://localhost:9000/ecom-media

# ─── Elasticsearch ───────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ─── Email (MailHog local) ───────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@ecommerce.vn
MAIL_FROM_NAME=E-Commerce Platform

# ─── Payment Gateways (Sandbox) ──────────────────────────────
# VNPay
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=${APP_URL}/api/v1/payments/webhook/vnpay

# MoMo
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=${APP_URL}/api/v1/payments/webhook/momo

# Stripe
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PUBLISHABLE_KEY=pk_test_

# ─── Shipping ────────────────────────────────────────────────
# GHN (Giao Hàng Nhanh)
GHN_TOKEN=
GHN_SHOP_ID=
GHN_ENV=dev   # dev | prod

# GHTK
GHTK_TOKEN=
GHTK_PICK_PROVINCE=Hồ Chí Minh
GHTK_PICK_DISTRICT=Quận 1

# ─── SMS (Twilio hoặc Esms.vn) ───────────────────────────────
SMS_PROVIDER=esms   # esms | twilio
ESMS_API_KEY=
ESMS_API_SECRET=
ESMS_BRAND_NAME=Ecommerce

# ─── Rate Limiting ───────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=debug   # error | warn | log | debug | verbose

# ─── MinIO local ─────────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_pass_local
